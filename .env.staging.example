# Staging environment — copy to .env.staging and fill in values.
# Never commit .env.staging (it has real credentials).

# ── Supabase (staging project) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<staging-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# For local Docker-based staging (supabase start):
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-status>
# SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-status>

# ── Azure AD (same as prod — use the same app registration) ──────────────────
VITE_AZURE_CLIENT_ID=<prod-azure-client-id>
VITE_AZURE_TENANT_ID=<prod-azure-tenant-id>

# ── Xoro (use staging credentials if available, else point at prod read-only) ─
VITE_XORO_API_KEY=<xoro-api-key>
VITE_XORO_API_SECRET=<xoro-api-secret>

# ── Dropbox (dedicated staging folder, same app as prod) ─────────────────────
DROPBOX_APP_KEY=<dropbox-app-key>
DROPBOX_APP_SECRET=<dropbox-app-secret>
DROPBOX_REFRESH_TOKEN=<dropbox-refresh-token>

# ── Misc ──────────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=<staging-project-ref>
EDI_INBOUND_SHARED_SECRET=staging-edi-secret-change-me

# ── Smoke test ────────────────────────────────────────────────────────────────
# Base URL of the running API (Vercel dev or staging deployment)
STAGING_API_BASE_URL=http://localhost:3000
# Vendor API key created by staging-setup.mjs (filled in automatically)
STAGING_VENDOR_API_KEY=
