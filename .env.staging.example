# Staging environment — copy to .env.staging and fill in values.
# Never commit .env.staging (it has real credentials).
#
# Key safety guarantees in staging:
#   • XORO_WRITEBACK_ENABLED is intentionally absent — server blocks writeback
#     even if accidentally set (xoro-writeback.js checks VITE_APP_ENV=staging)
#   • Planning module is beta-only — add approved emails to ALLOWED_EMAILS
#   • Integrations are read-only — VITE_ENABLE_*_READONLY=true

# ── App environment ───────────────────────────────────────────────────────────
VITE_APP_ENV=staging

# ── Supabase (staging project — "design-calendar staging") ───────────────────
VITE_SUPABASE_URL=https://<staging-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# For local Docker-based staging (supabase start):
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-status>
# SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-status>

# ── Azure AD (same as prod — use the same app registration) ──────────────────
VITE_AZURE_CLIENT_ID=<prod-azure-client-id>
VITE_AZURE_TENANT_ID=<prod-azure-tenant-id>

# ── Xoro (use staging credentials if available, else point at prod read-only) ─
VITE_XORO_API_KEY=<xoro-api-key>
VITE_XORO_API_SECRET=<xoro-api-secret>

# ── Dropbox (dedicated staging folder, same app as prod) ─────────────────────
DROPBOX_APP_KEY=<dropbox-app-key>
DROPBOX_APP_SECRET=<dropbox-app-secret>
DROPBOX_REFRESH_TOKEN=<dropbox-refresh-token>

# ── Misc ──────────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=<staging-project-ref>
EDI_INBOUND_SHARED_SECRET=staging-edi-secret-change-me

# ── Inventory Planning feature flags (staging defaults) ──────────────────────
# Planning visible, but only to users in the allowed email list.
# Leave ALLOWED_EMAILS empty to allow all authenticated users in staging.
VITE_ENABLE_INVENTORY_PLANNING=true
VITE_ENABLE_INVENTORY_PLANNING_BETA_ONLY=true
VITE_INVENTORY_PLANNING_ALLOWED_EMAILS=eran@ringoffireclothing.com

# ── Integration safety (read-only in staging) ─────────────────────────────────
VITE_ENABLE_XORO_READONLY=true
VITE_ENABLE_SHOPIFY_READONLY=true
VITE_ENABLE_ERP_WRITEBACK=false
# XORO_WRITEBACK_ENABLED is intentionally not set — writeback is blocked in
# staging at the server level regardless of this flag.

# ── Smoke test ────────────────────────────────────────────────────────────────
# Base URL of the running API (Vercel dev or staging deployment)
STAGING_API_BASE_URL=http://localhost:3000
# Vendor API key created by staging-setup.mjs (filled in automatically)
STAGING_VENDOR_API_KEY=

# ── Design Calendar scriptable API token ─────────────────────────────────────
# Bearer token for the daily-design-calendar-sync skill endpoints:
#   POST /api/ats/upload
#   POST /api/planning/sync-on-hand
#   POST /api/planning/sync-open-pos
# Generate with: openssl rand -hex 32
DESIGN_CALENDAR_API_TOKEN=
