# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.

# ── App environment ───────────────────────────────────────────────────────────
# Controls feature flags, staging banner, and writeback safety defaults.
# Values: development | staging | production
# Default when unset: development
VITE_APP_ENV=development

# ── Supabase (shared by internal apps and vendor portal) ─────────────────────
# Client-safe — bundled into the frontend. Anon key is RLS-gated.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only. Never prefix with VITE_ — would leak into the frontend.
# Used by api/vendor-invite.js (Supabase Auth admin.inviteUserByEmail) and any
# future serverless function that needs to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Inventory Planning feature flags ─────────────────────────────────────────
# VITE_ENABLE_INVENTORY_PLANNING: show the planning module at all.
#   development default: true  |  staging default: true  |  prod default: false
# VITE_ENABLE_INVENTORY_PLANNING_BETA_ONLY: restrict to allowed emails.
#   development default: false |  staging default: true  |  prod default: true
# VITE_INVENTORY_PLANNING_ALLOWED_EMAILS: comma-separated list of PLM usernames.
#   Empty = allow all authenticated users (when beta_only=true).
VITE_ENABLE_INVENTORY_PLANNING=true
VITE_ENABLE_INVENTORY_PLANNING_BETA_ONLY=false
VITE_INVENTORY_PLANNING_ALLOWED_EMAILS=

# ── Integration safety flags ──────────────────────────────────────────────────
# Read-only mode blocks frontend write paths.
# Server-side writeback also requires XORO_WRITEBACK_ENABLED=1 (see below).
VITE_ENABLE_XORO_READONLY=true
VITE_ENABLE_SHOPIFY_READONLY=true
VITE_ENABLE_ERP_WRITEBACK=false

# ── Xoro (per-Private-App credentials) ──────────────────────────────────────
# Xoro provisions a separate Private App per permission scope. Each app
# generates its own Key + Secret, scoped to specific endpoints. xoro-client.js
# routes calls to the right pair via the `module` argument:
#
#   module: undefined / default  → VITE_XORO_API_KEY / SECRET
#   module: "items"              → VITE_XORO_ITEMS_API_KEY / SECRET
#   module: "sales"              → VITE_XORO_SALES_API_KEY / SECRET
#
# Mapping of Private Apps to env vars in this project:
#
#   App "PO To ASN Workflow" — purchaseorder/getpurchaseorder
#     → VITE_XORO_API_KEY / SECRET (default; consumed by xoro-proxy.js
#       for TandA's PO sync, and any handler that doesn't pass module=)
#
#   App "ATS App" (scope: Inventory and Sales Orders) — salesorder/getsalesorder
#     → VITE_XORO_ITEMS_API_KEY / SECRET (consumed via module=items by
#       xoro/open-sos.js, xoro-items-missing-sync.js, xoro/inventory-snapshot.js)
#
#   App "Sales History" (scope: Invoices) — invoice/getinvoice
#     → VITE_XORO_SALES_API_KEY / SECRET (consumed via module=sales by
#       xoro-sales-sync.js for wholesale sales-history backfills)
#
#   App "Bill & Item Receipt Management" — bill/getbill, bill/getitemreceipt
#     → VITE_XORO_BILL_API_KEY / SECRET (consumed via module=bill by
#       xoro-receipts-sync.js for 3-way PO ↔ Receipt ↔ Vendor Invoice match)
#
# Inventory/Item-master read endpoint: NOT YET KNOWN. The ATS App's scope
# label says "Inventory and Sales Orders" but every item/inventory path
# we've probed returns 500. Pending Xoro support reply.
VITE_XORO_API_KEY=
VITE_XORO_API_SECRET=
VITE_XORO_ITEMS_API_KEY=
VITE_XORO_ITEMS_API_SECRET=
VITE_XORO_SALES_API_KEY=
VITE_XORO_SALES_API_SECRET=
VITE_XORO_BILL_API_KEY=
VITE_XORO_BILL_API_SECRET=
# Enable live Xoro writeback (server-side). NEVER set to 1 in staging.
# Staging blocks writeback even if this is accidentally set.
XORO_WRITEBACK_ENABLED=

# ── Azure AD (internal SSO, optional) ────────────────────────────────────────
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=

# ── Searates (vendor portal shipment tracking, Phase 1.6–1.9) ────────────────
# Server-side only. Used by api/searates-proxy.js. Every call is user-initiated
# — no cron/polling. Each live refresh is a billable API call.
SEARATES_API_KEY=

# ── Walmart Marketplace (Tangerine P12b — direct integration) ────────────────
# AES-256-GCM key (server-side only) used to encrypt the per-seller
# client_credentials OAuth pair (client_id + client_secret) at rest in the
# walmart_seller_accounts table. Generate with:
#   openssl rand -hex 32
# Must be exactly 64 hex chars (32 bytes). Decryption is service-role only.
WALMART_TOKEN_ENC_KEY=

# ── Faire wholesale marketplace (P12c-2) ─────────────────────────────────────
# AES-256-GCM key for encrypting/decrypting the Faire static API key at rest
# in faire_shops.api_key_ciphertext / iv / tag. Server-side only — never
# prefix with VITE_. Generate with: openssl rand -hex 32  (64 hex chars).
# When unset, the nightly + monthly Faire crons short-circuit with
# {ok: true, skipped: "Faire not configured (FAIRE_TOKEN_ENC_KEY missing)"}.
FAIRE_TOKEN_ENC_KEY=

# ── Design Calendar scriptable API token ─────────────────────────────────────
# Bearer token gating the three endpoints driven by the
# daily-design-calendar-sync skill:
#   • POST /api/ats/upload
#   • POST /api/planning/sync-on-hand
#   • POST /api/planning/sync-open-pos
# Generate with: openssl rand -hex 32
# Compare uses crypto.timingSafeEqual (constant-time). When unset, all
# three endpoints return 500 — these surfaces must be locked before deploy.
DESIGN_CALENDAR_API_TOKEN=
