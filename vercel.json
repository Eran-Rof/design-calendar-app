{
  "installCommand": "npm install --prefer-offline --no-audit",
  "buildCommand": "npm run build",
  "devCommand": "vite --port $PORT --strictPort",
  "rewrites": [
    { "source": "/api/dispatch", "destination": "/api/dispatch" },
    { "source": "/api/:rest*", "destination": "/api/dispatch?__fullpath=/api/:rest*" },
    { "source": "/((?!api/|@|src/|node_modules/|assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/compliance-daily", "schedule": "0 14 * * *" },
    { "path": "/api/cron/contracts-daily", "schedule": "0 15 * * *" },
    { "path": "/api/cron/customer-contact-reminders", "schedule": "0 * * * *" },
    { "path": "/api/cron/scorecards-monthly", "schedule": "0 6 1 * *" },
    { "path": "/api/cron/early-payment-analytics", "schedule": "0 8 2 * *" },
    { "path": "/api/cron/anomalies-nightly", "schedule": "0 8 * * *" },
    { "path": "/api/cron/health-scores-monthly", "schedule": "0 7 1 * *" },
    { "path": "/api/cron/push-delivery", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/notifications-email-drain", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/ip-freshness-refresh", "schedule": "0 */4 * * *" },
    { "path": "/api/cron/tpl-inventory-pull", "schedule": "30 2 * * *" },
    { "path": "/api/cron/ip-integration-health", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/xoro-feed-health-alert", "schedule": "0 13 * * *" },
    { "path": "/api/cron/app-errors-digest", "schedule": "5 13 * * *" },
    { "path": "/api/cron/ar-receipts-reconcile", "schedule": "0 5 * * *" },
    { "path": "/api/cron/insights-weekly", "schedule": "0 6 * * 1" },
