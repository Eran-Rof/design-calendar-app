{
  "name": "design-calendar-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node scripts/dev-api-server.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && node scripts/setup-vercel.mjs && vercel --prod --prebuilt",
    "test": "vitest run",
    "typecheck": "node scripts/typecheck-ratchet.mjs",
    "typecheck:update": "node scripts/typecheck-ratchet.mjs --update",
    "typecheck:raw": "tsc -b --force",
    "check:api": "node scripts/check-api.mjs",
    "audit:pos": "node scripts/audit-pos.mjs",
    "data-quality": "node scripts/po-data-quality.mjs",
    "sync-health": "node scripts/sync-health.mjs",
    "gen:routes": "node scripts/gen-routes.mjs",
    "gen:module-keys": "node scripts/gen-module-keys.mjs",
    "seed:module-keys": "node scripts/seed-module-keys.mjs",
    "test:eval": "RUN_AI_EVAL=1 vitest run api/_lib/ai/__tests__/golden-questions.test.js",
    "staging:local": "node scripts/staging-setup.mjs --local",
    "staging:remote": "node scripts/staging-setup.mjs --remote",
    "staging:smoke": "node scripts/staging-smoke.mjs",
    "staging:reset": "node scripts/staging-setup.mjs --local --reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tiptap/extension-bullet-list": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-font-family": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-ordered-list": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "exceljs": "^4.4.0",
    "formidable": "^3.5.4",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "sharp": "^0.33.5",
    "ssh2-sftp-client": "^11.0.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.1.1",
    "supabase": "^2.91.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vitest": "^2.1.9"
  }
}
